{
  "realm": "techgarden",
  "enabled": true,
  "registrationAllowed": false,
  "clientScopes": [
    {
      "name": "api.blog",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "api.blog-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "api.blog",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "api.profile",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "api.profile-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "api.profile",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "app_admin",
        "description": "Application administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "bff",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_CLIENT_BFF_SECRET}",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "basic",
        "profile",
        "email",
        "offline_access",
        "api.blog",
        "api.profile"
      ]
    },
    {
      "clientId": "svc.profile",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_CLIENT_PROFILE_SECRET}",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "openid",
        "basic",
        "api.blog",
        "api.profile"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "accounts",
      "displayName": "Sign in with Accounts",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "issuer": "https://sso.dev.techgarden.gg/realms/accounts",
        "authorizationUrl": "https://sso.dev.techgarden.gg/realms/accounts/protocol/openid-connect/auth",
        "tokenUrl": "https://sso.dev.techgarden.gg/realms/accounts/protocol/openid-connect/token",
        "userInfoUrl": "https://sso.dev.techgarden.gg/realms/accounts/protocol/openid-connect/userinfo",
        "logoutUrl": "https://sso.dev.techgarden.gg/realms/accounts/protocol/openid-connect/logout",
        "jwksUrl": "https://sso.dev.techgarden.gg/realms/accounts/protocol/openid-connect/certs",
        "useJwksUrl": "true",
        "validateSignature": "true",
        "clientId": "broker-techgarden",
        "clientSecret": "${KC_BROKER_TECHGARDEN_SECRET}",
        "syncMode": "FORCE",
        "defaultScope": "openid profile email"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "hardcoded-app_admin",
      "identityProviderAlias": "accounts",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "role": "app_admin",
        "syncMode": "INHERIT"
      }
    }
  ],
  "users": [
    {
      "username": "techgardencode",
      "email": "techgardencode+dev@techgarden.gg",
      "firstName": "TechGarden",
      "lastName": "Code",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KC_USER_TECHGARDENCODE_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "app_admin"
      ],
      "clientRoles": {
        "realm-management": [
          "realm-admin"
        ]
      }
    },
    {
      "username": "techgardenadmin",
      "email": "techgardenadmin+dev@techgarden.gg",
      "firstName": "TechGarden",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KC_USER_TECHGARDENADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "app_admin"
      ]
    },
    {
      "username": "techgardenuser",
      "email": "techgardenuser+dev@techgarden.gg",
      "firstName": "TechGarden",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KC_USER_TECHGARDENUSER_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
