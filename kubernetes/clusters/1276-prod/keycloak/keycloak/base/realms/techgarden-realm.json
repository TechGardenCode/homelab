{
  "realm": "techgarden",
  "enabled": true,
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "bff",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_CLIENT_BFF_SECRET}",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "offline_access"
      ]
    },
    {
      "clientId": "svc.profile",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_CLIENT_PROFILE_SECRET}",
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "identityProviders": [
    {
      "alias": "accounts",
      "displayName": "Sign in with Accounts",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "issuer": "https://sso.techgarden.gg/realms/accounts",
        "authorizationUrl": "https://sso.techgarden.gg/realms/accounts/protocol/openid-connect/auth",
        "tokenUrl": "https://sso.techgarden.gg/realms/accounts/protocol/openid-connect/token",
        "userInfoUrl": "https://sso.techgarden.gg/realms/accounts/protocol/openid-connect/userinfo",
        "logoutUrl": "https://sso.techgarden.gg/realms/accounts/protocol/openid-connect/logout",
        "jwksUrl": "https://sso.techgarden.gg/realms/accounts/protocol/openid-connect/certs",
        "useJwksUrl": "true",
        "validateSignature": "true",
        "clientId": "broker-techgarden",
        "clientSecret": "${KC_BROKER_TECHGARDEN_SECRET}",
        "syncMode": "FORCE",
        "defaultScope": "openid profile email"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "hardcoded-app_admin",
      "identityProviderAlias": "accounts",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "role": "app_admin",
        "syncMode": "INHERIT"
      }
    }
  ]
}
